generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  durationMin Int
  price       Int
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, sortOrder])
}

model Customer {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String   @default("")
  phone     String   @unique
  email     String   @default("")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@index([firstName, lastName])
  @@index([phone])
}

model Appointment {
  id              Int               @id @default(autoincrement())
  serviceId       Int
  serviceName     String
  serviceDuration Int
  servicePrice    Int
  date            String
  time            String
  customerId      Int?
  customer        Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  customerPhone   String
  customerEmail   String
  notes           String?
  inspoIds        String            @default("")
  status          AppointmentStatus @default(pending)
  reminderSentAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([date, time])
  @@index([status])
  @@index([customerId])
}

model WorkingHours {
  id        Int      @id @default(autoincrement())
  dayOfWeek Int      @unique
  isOpen    Boolean  @default(true)
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockedDate {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InspoImage {
  id        Int      @id @default(autoincrement())
  src       String
  label     String
  tags      String   @default("")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}
